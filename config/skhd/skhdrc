# Focus window
alt - left : yabai -m window --focus west
alt - down : yabai -m window --focus south
alt - up : yabai -m window --focus north
alt - right : yabai -m window --focus east

# Move/swap window
ctrl + alt - a : yabai -m window --warp west
ctrl + alt - s : yabai -m window --warp south
ctrl + alt - w : yabai -m window --warp north
ctrl + alt - d : yabai -m window --warp east

# Grow window
ctrl + alt - left : yabai -m window --resize left:-50:0
ctrl + alt - down : yabai -m window --resize bottom:0:50
ctrl + alt - up : yabai -m window --resize top:0:-50
ctrl + alt - right : yabai -m window --resize right:50:0

# Shrink window
shift + ctrl + alt - left : yabai -m window --resize left:50:0
shift + ctrl + alt - down : yabai -m window --resize bottom:0:-50
shift + ctrl + alt - up : yabai -m window --resize top:0:50
shift + ctrl + alt - right : yabai -m window --resize right:-50:0

# Switch spaces
alt - 1 : yabai -m space --focus 1
alt - 2 : yabai -m space --focus 2
alt - 3 : yabai -m space --focus 3
alt - 4 : yabai -m space --focus 4
alt - 5 : yabai -m space --focus 5

# Create/destroy space
shift + alt - n : yabai -m space --create && yabai -m space --focus "$(yabai -m query --spaces | python3 -c 'import sys,json; print(json.load(sys.stdin)[-1]["index"])')"
shift + alt - x : yabai -m space --destroy

# Move window to space
shift + alt - 1 : yabai -m window --space 1; yabai -m space --focus 1
shift + alt - 2 : yabai -m window --space 2; yabai -m space --focus 2
shift + alt - 3 : yabai -m window --space 3; yabai -m space --focus 3
shift + alt - 4 : yabai -m window --space 4; yabai -m space --focus 4
shift + alt - 5 : yabai -m window --space 5; yabai -m space --focus 5

# Toggle states
alt - return : yabai -m window --toggle zoom-fullscreen
alt - t : yabai -m window --toggle float
alt - e : yabai -m window --toggle split
alt - r : yabai -m space --rotate 90
alt - b : yabai -m space --balance

# Move window to next/prev display
ctrl + cmd - right : yabai -m window --display next; yabai -m display --focus next
ctrl + cmd - left : yabai -m window --display prev; yabai -m display --focus prev

# Cycle windows
alt - tab : yabai -m window --focus next || yabai -m window --focus first

# Launch apps
cmd + alt - return : open -na kitty
shift + cmd + alt - return : open -na "Zed"

# Restart services
shift + alt - r : yabai --restart-service
ctrl + alt - r : skhd --restart-service
